<odoo>
    <record id="view_invoice_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.edifact</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="generate_edifact_sagaflor"
                        type="object"
                        string="EDIFACT Sagaflor"
                        class="btn-primary"
                        icon="fa-download"/>
                <button name="generate_edifact_futterhaus"
                        type="object"
                        string="EDIFACT Futterhaus"
                        class="btn-primary"
                        icon="fa-download"/>
            </xpath>
            <xpath expr="//field[@name='to_check']" position="after">
                    <field name="note"/>
            </xpath>
        </field>
    </record>
</odoo>
