<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="edifact_view_company_form" model="ir.ui.view">
        <field name="name">edifact.view.company.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page name="edifact_info" string="Edifact Information">
                    <group>
                        <group>
                            <field name="futterhaus_edifact_invoiced_partner_id" />
                            <field name="sagaflor_edifact_invoiced_partner_id" />
                        </group>
                    </group>
                </page>    
            </notebook>
        </field>
    </record>

</odoo>
