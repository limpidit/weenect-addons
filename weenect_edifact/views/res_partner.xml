<odoo>

    <record id="edifact_res_partner_view_form" model="ir.ui.view">
        <field name="name">edifact.res.partner.view.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="EDI Export">
                    <group>
                        <field name="edi_export_format" widget="radio"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
