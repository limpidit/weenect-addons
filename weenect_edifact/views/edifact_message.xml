<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_edifact_message_list" model="ir.ui.view">
        <field name="name">edifact.message.list</field>
        <field name="model">edifact.message</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="message_type"/>
                <field name="state" widget="badge" decoration-success="state == 'sent'" decoration-danger="state == 'error'"/>
                <field name="sender_id" />
                <field name="receiver_id" />
            </list>
        </field>
    </record>

    <record id="view_edifact_message_form" model="ir.ui.view">
        <field name="name">edifact.message.form</field>
        <field name="model">edifact.message</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" invisible="1"/>
                    <button name="generate_edifact_content" type="object" string="Generate EDIFACT Content" class="btn-primary"/>
                    <button name="link_moves" type="object" string="Link Moves" class="btn-secondary" invisible="state not in ('draft')"/>
                    <button name="set_to_draft" type="object" string="Reset to Draft" class="btn-secondary" invisible="state not in ('draft')"/>
                    <button name="action_send_edifact_message" type="object" string="Send by email" class="btn-secondary"/>
                    <button name="mark_moves_as_sent" type="object" string="Mark Moves as Sent" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,linked,sent" />
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="message_type" widget="radio"/>
                        </group>
                        <group>
                            <field name="sender_id" />
                            <field name="receiver_id" />
                            <field name="error_message"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="edifact_content" string="Exchange Content">
                            <field name="message_content" type="text"/>
                        </page>
                        <page name="related_moves" string="Related Moves">
                            <field name="move_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="amount_total"/>
                                    <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-danger="state == 'draft'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_edifact_message" model="ir.actions.act_window">
        <field name="name">EDIFACT Messages</field>
        <field name="res_model">edifact.message</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="edifact_message_menu"
        name="Edifact Messages"
        parent="accountant.menu_accounting"
        action="action_edifact_message"
        sequence="10"/>
        
</odoo>