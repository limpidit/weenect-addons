<odoo>

    <record id="view_res_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.weenect.edifact</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='account_digitalization']" position="after">
                <block title="Edifact" id="edifact_settings">
                    <setting id="sender_gln" string="GLN expéditeur">
                        <field name="sender_gln_id" options="{'no_create': True, 'no_open': True}"/>
                    </setting>
                    <setting id="sagaflor_gln" string="GLN Sagaflor">
                        <field name="sagaflor_gln_id" options="{'no_create': True, 'no_open': True}"/>
                    </setting>
                    <setting id="futterhaus_gln" string="GLN Futterhaus">
                        <field name="futterhaus_gln_id" options="{'no_create': True, 'no_open': True}"/>
                    </setting>
                </block>                
            </xpath>
        </field>
    </record>

</odoo>
