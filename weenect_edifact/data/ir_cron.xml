<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="sagaflor_edifact_cron" model="ir.cron">
            <field name="name">EDIFACT : Sending Sagaflor edifact attachments</field>
            <field name="model_id" ref="model_account_move"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="False"/>
            <field name="state">code</field>
            <field name="code">
                moves = model.search([('state', '=', 'posted'), ('partner_id.export_format', '=', 'd96a')])
                moves.cron_send_sagaflor_edifact_attachments()
            </field>
        </record>
    
    </data>
    

</odoo>
