<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="sagaflor_edifact_cron" model="ir.cron">
            <field name="name">EDIFACT : Generating Sagaflor message</field>
            <field name="model_id" ref="model_edifact_message"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_sagaflor_edifact_message()</field>
        </record>

        <record id="futterhaus_edifact_cron" model="ir.cron">
            <field name="name">EDIFACT : Generating Futterhaus message</field>
            <field name="model_id" ref="model_edifact_message"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_futterhaus_edifact_message()</field>
        </record>
    
    </data>
    

</odoo>
