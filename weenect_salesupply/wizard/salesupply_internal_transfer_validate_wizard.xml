<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_salesupply_internal_transfer_validate_wizard_form" model="ir.ui.view">
        <field name="name">salesupply.internal.transfer.validate.wizard.form</field>
        <field name="model">salesupply.internal.transfer.validate.wizard</field>
        <field name="arch" type="xml">
            <form string="Execute synchronization of receptions">
                <group>
                    <group>
                        <field name="shop_id" readonly="1"/>
                        <field name="warehouse_ids" widget="many2many_tags" required="1" /> 
                    </group>
                    <group>
                        <field name="date_from_synchronization" />
                    </group>
                </group>
                <footer>
                    <button string="Execute" type="object" name="synchronize_receptions" class="oe_highlight"/>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
