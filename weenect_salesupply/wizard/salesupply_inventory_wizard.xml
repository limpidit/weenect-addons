<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_salesupply_inventory_wizard" model="ir.ui.view">
        <field name="name">salesupply.inventory.wizard.form</field>
        <field name="model">salesupply.inventory.wizard</field>
        <field name="arch" type="xml">
            <form string="Execute inventory">
                <group>
                    <field name="shop_id" readonly="1"/>
                    <field name="warehouse_ids" widget="many2many_tags" required="1" />
                </group>
                <footer>
                    <button string="Execute" type="object" name="synchronize_inventory" class="oe_highlight"/>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>    

</odoo>
