<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_salesupply" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.salesupply</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <div name="warehouse_setting_container" position="after">
                    <h2 class="mt32">Salesupply connector</h2>
                    <div class="row mt16 o_settings_container" name="salesupply_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <div>
                                    <label for="salesupply_api_host" class="col-lg-3"/>
                                    <field name="salesupply_api_host" class="ms-2"/>
                                </div>
                                <div>
                                    <label for="salesupply_api_username" class="col-lg-3"/>
                                    <field name="salesupply_api_username" class="ms-2"/>
                                </div>
                                <div>
                                    <label for="salesupply_api_password" class="col-lg-3"/>
                                    <field name="salesupply_api_password" class="ms-2" password="True"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </field>
        </record>
    </data>
</odoo>
