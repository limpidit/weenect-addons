<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="salesupply_product_template_view_tree" model="ir.ui.view">
        <field name="name">salesupply.product.template.view.tree</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="product_variant_count" position="before">
                <header>
                    <button string="Upload to Salesupply" type="object" name="action_open_send_product_wizard"/>
                </header>
            </field>
        </field>
    </record>

    <record id="salesupply_product_template_form_view" model="ir.ui.view">
        <field name="name">salesupply.product.template.form.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <sheet position="before">
                <header>
                    <button string="Upload to Salesupply" type="object" name="action_open_send_product_wizard" class="btn-primary"/>
                </header>
            </sheet>
            <div name="options" position="inside">
                <span class="d-inline-block">
                    <field name="available_on_salesupply" readonly="1"/>
                    <label for="available_on_salesupply"/>
                </span>
            </div>
            <notebook position="inside">
                <page name="salesupply_info" string="Salesupply" invisible="not available_on_salesupply">
                    <field name="salesupply_shop_product_ids">
                        <list string="Salesupply products Shop" editable="bottom" create="0" edit="0">
                            <field name="id_shop_group" />
                            <field name="id_salesupply" />
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

    <record id="salesupply_product_template_action_server" model="ir.actions.server">
        <field name="name">Salesupply Products Action</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_products()</field>
    </record>

    <record id="salesupply_product_template_action" model="ir.actions.act_window">
        <field name="name">Products available on Salesupply</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('available_on_salesupply', '=', True)]</field>
        <field name="context">
            {
                'salesupply': True,
                'search_default_consumable': 1, 
                'default_detailed_type': 'product'
            }
        </field>
    </record>

</odoo>