<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="salesupply_product_template_form_view" model="ir.ui.view">
        <field name="name">salesupply.product.template.form.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <div name="options" position="inside">
                <span class="d-inline-block">
                    <field name="available_on_salesupply"/>
                    <label for="available_on_salesupply"/>
                </span>
            </div>
            <notebook position="inside">
                <page name="salesupply_info" string="Salesupply" attrs="{'invisible': [('available_on_salesupply', '=', False)]}">
                    <field name="salesupply_shop_product_ids">
                        <tree string="Salesupply products Shop" editable="bottom" create="0" edit="0">
                            <field name="id_shop_group" />
                            <field name="id_salesupply" />
                        </tree>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

    <record id="salesupply_product_template_action" model="ir.actions.act_window">
        <field name="name">Products available on Salesupply</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('available_on_salesupply', '=', True)]</field>
        <field name="context">
            {
                'salesupply': True,
                'search_default_consumable': 1, 
                'default_detailed_type': 'product'
            }
        </field>
    </record>

</odoo>