<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="salesupply_receptions_action" model="ir.actions.act_window">
        <field name="name">Internal transfers to Salesupply warehouses</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_transfered_to_salesupply', '=', True)]</field>
        <field name="context">{'contact_display': 'partner_address', 'default_company_id': allowed_company_ids[0]}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transfer found. Let's create one!
            </p><p>
                Transfers allow you to move products from one location to another.
            </p>
        </field>
    </record>

    <record id="salesupply_deliveries_action" model="ir.actions.act_window">
        <field name="name">Deliveries from Salesupply warehouses</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_delivered_from_salesupply', '=', True)]</field>
        <field name="context">{'contact_display': 'partner_address', 'default_company_id': allowed_company_ids[0]}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transfer found. Let's create one!
            </p><p>
                Transfers allow you to move products from one location to another.
            </p>
        </field>
    </record>

    <record id="salesupply_returns_action" model="ir.actions.act_window">
        <field name="name">Returns to Salesupply warehouses</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_returned_to_salesupply', '=', True)]</field>
        <field name="context">{'contact_display': 'partner_address', 'default_company_id': allowed_company_ids[0]}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transfer found. Let's create one!
            </p><p>
                Transfers allow you to move products from one location to another.
            </p>
        </field>
    </record>

    <record id="salesupply_stock_picking_view_form" model="ir.ui.view">
        <field name="name">salesupply.stock.picking.view.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page name="salesupply" string="Salesupply">
                    <group>
                        <group>
                            <field name="salesupply_synchronized"/>
                            <field name="salesupply_code"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
