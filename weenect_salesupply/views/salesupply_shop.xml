<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="salesupply_shop_view_tree" model="ir.ui.view">
        <field name="name">salesupply.shop.view.tree</field>
        <field name="model">salesupply.shop</field>
        <field name="arch" type="xml">
            <tree string="Shops">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="salesupply_shop_view_form" model="ir.ui.view">
        <field name="name">salesupply.shop.view.form</field>
        <field name="model">salesupply.shop</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Link products" name="get_products_from_salesupply" 
                        groups="stock.group_stock_manager"
                        type="object" class="oe_highlight"/>
                    <button string="Synchronize inventory" name="action_open_inventory_wizard" 
                        groups="stock.group_stock_manager"
                        type="object" class="oe_highlight"/>
                    <button string="Synchronize receptions" name="action_open_internal_transfer_synchronization_wizard" 
                        groups="stock.group_stock_manager"
                        type="object" class="oe_highlight"/>
                    <button string="Synchronize shipments" name="action_open_shipment_synchronization_wizard" 
                        groups="stock.group_stock_manager"
                        type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Shop"/></h1>
                    </div>
                    <group>
                        <group name="salesupply_info" string="Salesupply information">
                            <field name="id_salesupply" />
                            <field name="shop_group_id_salesupply" />
                            <field name="shop_owner_id_salesupply" />
                        </group>
                    </group>
                    <notebook>
                        <page name="deliveries" string="Deliveries synchronization">
                            <group>
                                <group>
                                    <field name="sale_done_status_ids" widget="many2many_tags"/>
                                    <field name="shippings_default_customer_id" />
                                    <field name="last_orders_synchronization_date" />
                                </group>
                            </group>
                        </page>
                        <page name="receptions" string="Receptions synchronization">
                            <group>
                                <group>
                                    <field name="last_internal_transfers_synchronization_date" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="salesupply_shop_action" model="ir.actions.act_window">
        <field name="name">Salesupply shops</field>
        <field name="res_model">salesupply.shop</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
