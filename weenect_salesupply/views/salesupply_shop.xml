<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="salesupply_shop_view_tree" model="ir.ui.view">
        <field name="name">salesupply.shop.view.tree</field>
        <field name="model">salesupply.shop</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" string="Shops">
                <field name="name" />
                <field name="id_salesupply" />
                <field name="shop_owner_id_salesupply" />
                <field name="shop_group_id_salesupply" />
            </tree>
        </field>
    </record>

    <record id="salesupply_shop_action" model="ir.actions.act_window">
        <field name="name">Salesupply shops</field>
        <field name="res_model">salesupply.shop</field>
        <field name="view_mode">tree</field>
    </record>

</odoo>
