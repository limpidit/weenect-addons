<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="salesupply_synchronization_view_tree" model="ir.ui.view">
        <field name="name">salesupply.synchronization.view.tree</field>
        <field name="model">salesupply.synchronization</field>
        <field name="arch" type="xml">
            <tree string="Synchronization actions" create="0">
                <field name="name" />
                <field name="synchronizated_data" />
                <field name="state" widget="badge"
                    decoration-danger="state == 'failed'" 
                    decoration-info="state == 'new'"
                    decoration-success="state == 'done'" 
                    decoration-warning="state == 'processing'"/>
            </tree>
        </field>
    </record>

    <record id="salesupply_synchronization_view_form" model="ir.ui.view">
        <field name="name">salesupply.synchronization.view.form</field>
        <field name="model">salesupply.synchronization</field>
        <field name="arch" type="xml">
            <form>
                <field name="state" invisible="1"/>
                <header>
                    <button string="Execute manually" name="execute" type="object" attrs="{'invisible': [('state', '!=', 'new')]}" class="btn-primary"/>
                    <button string="Put back to new" name="put_state_to_new" type="object" attrs="{'invisible': [('state', '!=', 'failed')]}" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,processing,failed,done"/>
                </header>
                <sheet>
                    <group string="Synchronization information">
                        <field name="name" />
                        <field name="synchronizated_data" />
                        <field name="connection_id" />
                        <field name="synchronization_done_date" />
                    </group>
                    <notebook>
                        <page name="logs" string="Logs">
                            <field name="message_ids" mode="tree">
                                <tree create="0" edit="0" delete="0">
                                    <field name="title" />
                                    <field name="logs" />
                                    <field name="create_date" />
                                    <field name="type" widget="badge" 
                                        decoration-danger="type == 'error'" 
                                        decoration-info="type == 'info'"
                                        decoration-warning="type == 'warning'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="salesupply_synchronization_view_search" model="ir.ui.view">
        <field name="name">salesupply.synchronization.view.search</field>
        <field name="model">salesupply.synchronization</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Action" filter_domain="[('name', 'ilike', self)]"/>
                <filter name="new" string="New actions" domain="[('state', '=', 'new')]" />
                <filter name="processing" string="Processing actions" domain="[('state', '=', 'processing')]" />
                <filter name="failed" string="Failed actions" domain="[('state', '=', 'failed')]" />
                <group name="group_by" string="Group By">
                    <filter name="state" string="State" domain="[]" context="{'group_by': 'state'}" />
                    <filter name="data" string="Synchronized data" domain="[]" context="{'group_by': 'synchronizated_data'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="salesupply_synchronization_action" model="ir.actions.act_window">
        <field name="name">Synchronization actions</field>
        <field name="res_model">salesupply.synchronization</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '!=', 'done')]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p>Open current salesupply synchronization actions</p>
        </field>
    </record>

    <record id="done_salesupply_synchronization_action" model="ir.actions.act_window">
        <field name="name">Synchronization finished actions</field>
        <field name="res_model">salesupply.synchronization</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'done')]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p>Open finished salesupply synchronization actions</p>
        </field>
    </record>

</odoo>
