<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crosslog_order_state_view_tree" model="ir.ui.view">
        <field name="name">crosslog.order.state.view.tree</field>
        <field name="model">crosslog.order.state</field>
        <field name="arch" type="xml">
            <list string="Crosslog orders state" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="crosslog_order_state_action" model="ir.actions.act_window">
        <field name="name">Crosslog orders state</field>
        <field name="res_model">crosslog.order.state</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
