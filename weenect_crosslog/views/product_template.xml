<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crosslog_product_template_action_server" model="ir.actions.server">
        <field name="name">Crosslog Products Action</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_crosslog_products()</field>
    </record>

    <record id="crosslog_product_template_action" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('available_on_crosslog', '=', True)]</field>
        <field name="context">
            {
                'crosslog': True,
                'search_default_consumable': 1, 
                'default_detailed_type': 'product'
            }
        </field>
    </record>

    <record id="crosslog_product_template_view_form" model="ir.ui.view">
        <field name="name">crosslog.product.template.view.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <div name="options" position="inside">
                <span class="d-inline-block">
                    <field name="available_on_crosslog" readonly="1"/>
                    <label for="available_on_crosslog"/>
                </span>
            </div>
        </field>
    </record>

</odoo>
