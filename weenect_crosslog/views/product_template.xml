<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crosslog_product_template_action_server" model="ir.actions.server">
        <field name="name">Crosslog Products Action</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_crosslog_products()</field>
    </record>

    <record id="crosslog_product_template_list" model="ir.ui.view">
        <field name="name">crosslog.product.template.list</field>
        <field name="model">product.template</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="default_code"/>
                    <field name="qty_available"/>
                    <field name="crosslog_qty" />
                    <field name="virtual_available" />
                </list>
            </field>
    </record>

    <record id="crosslog_product_template_view_form" model="ir.ui.view">
        <field name="name">crosslog.product.template.view.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <div name="options" position="inside">
                <span class="d-inline-block">
                    <field name="available_on_crosslog"/>
                    <label for="available_on_crosslog"/>
                </span>
            </div>
        </field>
    </record>

</odoo>
