<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crosslog_connection_view_tree" model="ir.ui.view">
        <field name="name">crosslog.connection.view.tree</field>
        <field name="model">crosslog.connection</field>
        <field name="arch" type="xml">
            <tree string="Crosslog API configs">
                <field name="name" />
                <field name="api_url"/>
            </tree>
        </field>
    </record>

    <record id="crosslog_connection_view_form" model="ir.ui.view">
        <field name="name">crosslog.connection.view.form</field>
        <field name="model">crosslog.connection</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. API connection"/></h1>
                    </div>
                    <group>
                        <group string="API connection">
                            <field name="api_url" />
                            <field name="username" />
                            <field name="password" password="True" />
                        </group>
                        <group string="Other">
                            <field name="warehouse_id" />
                            <field name="crosslog_order_state_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="crosslog_connection_action" model="ir.actions.act_window">
        <field name="name">Crosslog Connection</field>
        <field name="res_model">crosslog.connection</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
