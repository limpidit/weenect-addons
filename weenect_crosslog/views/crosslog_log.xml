<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="salesupply_log_view_tree" model="ir.ui.view">
        <field name="name">crosslog.log.view.tree</field>
        <field name="model">crosslog.log</field>
        <field name="arch" type="xml">
            <list string="Data retrieving from crosslog history">
                <field name="name" />
                <field name="execution_date" />
                <field name="type" widget="badge" 
                    decoration-info="type == 'info'" 
                    decoration-danger="type == 'error'"
                    decoration-warning="type == 'warning'"/>
            </list>
        </field>
    </record>

    <record id="crosslog_log_view_form" model="ir.ui.view">
        <field name="name">crosslog.log.view.form</field>
        <field name="model">crosslog.log</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. API connection"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="execution_date"/>
                            <field name="type" widget="badge" 
                                decoration-info="type == 'info'" 
                                decoration-danger="type == 'error'"
                                decoration-warning="type == 'warning'"/>
                            <field name="message"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="crosslog_log_action" model="ir.actions.act_window">
        <field name="name">Data retrieving from Crosslog history</field>
        <field name="res_model">crosslog.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>
                See there the last executions of data retrieving from Crosslog to Odoo.
            </p>
        </field>
    </record>

</odoo>
