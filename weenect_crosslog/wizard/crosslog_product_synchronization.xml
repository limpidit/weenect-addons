<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crosslog_product_synchronization_wizard_view_form" model="ir.ui.view">
        <field name="name">crosslog.product.synchronization.wizard.form</field>
        <field name="model">crosslog.product.synchronization</field>
        <field name="arch" type="xml">
            <form string="Get Products from Crosslog">
                <sheet>
                    <group>
                        <field name="api_connection_id" required="1"/>
                        <field name="synchronize_stock"/>
                    </group>
                    <footer>
                        <button name="synchronize_products" string="Synchronize products" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="crosslog_product_synchronization_action" model="ir.actions.act_window">
        <field name="name">Synchronize products from Crosslog</field>
        <field name="res_model">crosslog.product.synchronization</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    
</odoo>