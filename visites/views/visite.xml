<odoo>

    <!-- Action pour inclure la vue Map -->
    <record id="action_visite" model="ir.actions.act_window">
        <field name="name">Visites</field>
        <field name="res_model">visite.visite</field>
        <field name="view_mode">list,form,map</field>
    </record>
    <record id="view_visite_form" model="ir.ui.view">
        <field name="name">visite.form</field>
        <field name="model">visite.visite</field>
        <field name="arch" type="xml">
            <form string="Visite" chatter="true">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': 1}"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="date_visite"/>
                        <field name="client_id"/>
                        <field name="tournee_id"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                        <field name="photos" widget="many2many_binary"/>
                        <field name="resume"/>
                        <field name="partner_latitude"/>
                        <field name="partner_longitude"/>
                    </group>
                </sheet>
            </form>

        </field>
    </record>

    <record id="list" model="ir.ui.view">
        <field name="name">visite.list</field>
        <field name="model">visite.visite</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="user_id"/>
                <field name="date_visite"/>
                <field name="client_id"/>
                <field name="tournee_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_visite_map" model="ir.ui.view">
        <field name="name">visite.map</field>
        <field name="model">visite.visite</field>
        <field name="arch" type="xml">
            <map string="Carte des Visites" res_partner="client_id" routing="true">
                <field name="name" string="Visite"/>
            </map>
        </field>
    </record>

    <record id="action_visites_map_by_tournee" model="ir.actions.act_window">
    <field name="name">Plan de tournée</field>
    <field name="res_model">visite.visite</field>
    <field name="view_mode">map,list,form</field>
    <field name="context">{}</field>
    <field name="domain">[]</field>
</record>



</odoo>
