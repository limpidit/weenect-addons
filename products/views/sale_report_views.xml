<odoo>
    <data>
        <!-- Hériter de la vue Pivot pour ajouter des champs -->
        <record id="view_sale_report_pivot_inherit_view" model="ir.ui.view">
            <field name="name">sale.order.line.pivot.inherit</field>
            <field name="model">sale.order.line</field>
            <field name="inherit_id" ref="products.view_sale_order_line_pivot_custom"/>
            <field name="arch" type="xml">
                <pivot position="inside">
                    <field name="country_id" type="row"/>
                    <field name="language_id" type="row"/>
                </pivot>
            </field>
        </record>
    </data>
</odoo>
