<odoo>
    <record id="view_sales_order_pivot_custom" model="ir.ui.view">
        <field name="name">sale.report.pivot</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_pivot"/>
        <field name="arch" type="xml">
        <xpath expr="//field[@name='date']" position="replace">
                <field name="product_id" type="row"/>
        </xpath>
        </field>
    </record>
        <record id="view_sale_order_line_pivot_custom" model="ir.ui.view">
            <field name="name">sale.order.line.pivot.custom</field>
            <field name="model">sale.order.line</field>
            <field name="arch" type="xml">
                <pivot string="Analyse des Ventes">
                    <field name="product_id" type="row"/>
                    <field name="name" type="row"/>
                    <field name="order_id" type="col"/>
                    <field name="product_uom_qty" type="measure"/>
                    <!-- Ajoutez ici d'autres champs si nécessaire -->
                </pivot>
            </field>
        </record>

        <record id="action_sale_order_line_pivot" model="ir.actions.act_window">
            <field name="name">Analyse des Ventes</field>
            <field name="res_model">sale.order.line</field>
            <field name="view_mode">pivot</field>
            <field name="view_id" ref="view_sale_order_line_pivot_custom"/>
        </record>

        <!-- Ajouter l'action au menu Ventes -->
        <menuitem id="menu_sale_order_line_pivot"
                  name="Analyse des Ventes"
                  parent="sale.menu_sale_report"
                  action="action_sale_order_line_pivot"/>

</odoo>
