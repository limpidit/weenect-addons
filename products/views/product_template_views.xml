<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="fleet.menu_root" model="ir.ui.menu">
        <field name='name'>Flotte Véhicules</field>
    </record>
    <record id="fleet.fleet_vehicle_action" model="ir.actions.act_window">
        <field name="name">Flotte Véhicules</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun relevé enregistré
            </p>
        </field>
    </record>
    <record id="view_order_form" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.vehicules</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="sda_file" />
                <field name="proposition_commercial" />
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="marque_vehicule_vendu" />
                <field name="genre_vehicule_vendu" />
                <field name="modele_commercial" />
                <field name="numero_affaire" />

            </xpath>
        </field>
    </record>

    <record id="fleet_vehicle_view_form_inherit" model="ir.ui.view">
        <field name="name">fleet.vehicle.inherit</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="replace">
                <form string="Vehicle" js_class="fleet_form" class="o_fleet_form">
                <field name="service_activity" invisible="1"/>
                <header>
                    <button string="Apply New Driver" class="btn btn-primary" type="object" name="action_accept_driver_change" attrs="{'invisible': [('future_driver_id', '=', False)]}"/>
                    <field name="state_id" widget="statusbar" options="{'clickable': '1'}"/>

                </header>
                <sheet>
                    <field name="company_id" invisible="1" />
                    <field name="currency_id" invisible="1"/>
                    <field name="country_code" invisible="1"/>
                    <field name="image_128" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="license_plate"/>
                        <h1>
                            <field name="license_plate" />
                        </h1>
                        <label for="acquisition_date"/>
                        <h2>
                            <field name="acquisition_date" class="oe_inline"/>
                        </h2>
                        <label for="category_id"/>
                        <h2>
                            <field name="category_id" class="oe_inline"/>
                        </h2>
                    </div>
                    <group col="2">
                        <group string="Vehicule">
                            <field name="model_id" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="future_driver_id" invisible="1" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="autre_modele" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="essieux" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="carrosserie" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="client_final" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="has_active_opportunity" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="contremarque_initiale" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                        </group>
                        <group string="Infos">
                            <field name="vin_sn" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="num_production" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="type_stock" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="num_affaire" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                            <field name="kilometrage" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dates">
                            <group>
                                <group>
                                    <field name="date_commande_daf" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="date_commande_client" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="date_production" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="semaine_production" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="annee_production" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="date_livraison_pl86" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="date_livraison_client" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                </group>
                                <group>
                                </group>
                            </group>
                        </page>
                        <page string="Infos complémentaires">
                            <group>
                                <group>
                                    <field name="localisation" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="carrossier" attrs="{&quot;invisible&quot;: [[&quot;localisation&quot;,&quot;!=&quot;,&quot;carrossier&quot;]]}"/>
                                    <field name="empatement" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="type_camion" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="prise_de_force" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="cabine" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="motorisation" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="rapport_de_pont" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="type_garantie" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                </group>
                                <group>
                                    <field name="type_boite" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="ralentisseur" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="reservoir" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="type_pneu" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="couleur" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="remarques" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="net_car_value" widget="monetary" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="prix_vente_prev" widget="monetary" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="date_ct" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                    <field name="date_derniere_revision" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Note">
                            <field name="description" nolabel="1" placeholder="Write here any other information related to this vehicle"/>
                        </page>
                        <page string="SDA">
                            <field name="sda" domain="[['is_sda','=',True]]" context="{'default_vehicle_id': active_id}" attrs="{'readonly': [('state_id', 'not in', [1,2])]}"/>
                        </page>
                        <page string="Opportunités">
                            <field name="lead_ids" domain="[('type', '=', 'opportunity')]" context="{'default_type': 'opportunity'}" attrs="{'readonly': [('state_id', 'not in', [1,2,3,4])]}"/>
                        </page>
                        <page string="Relevés Tachy">
                            <field name="releve_tachy" attrs="{'readonly': [('state_id', '!=', 1)]}"/>
                        </page>
                        <page string="Options">
                            <field name="options" attrs="{'readonly': [('state_id', 'not in', [1,2])]}"/>
                        </page>
                        <page string="Photos">
                            <field name="photo1" options="{&quot;size&quot;:[0,90]}" widget="image"/>
                            <field name="photo2" options="{&quot;size&quot;:[0,90]}" widget="image"/>
                            <field name="photo3" options="{&quot;size&quot;:[0,90]}" widget="image"/>
                            <field name="photo4" options="{&quot;size&quot;:[0,90]}" widget="image"/>
                            <field name="photo5" options="{&quot;size&quot;:[0,90]}" widget="image"/>
                        </page>
                        <page string="Rentabilité">
                            <field name="rentabilites_liees" attrs="{'readonly': [('state_id', 'not in', [1,2,3,4])]}"/>
                        </page>
                        <page string="Réservations">
                            <field name="reservation_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
            </xpath>
        </field>
    </record>
     <record id="action_fleet_vehicle_modele_camion" model="ir.actions.act_window">
        <field name="name">SDA</field>
        <field name="res_model">ir.attachment</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[["is_sda","=",True]]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune SDA
            </p>
        </field>
    </record>
    <record id="action_fleet_vehicle_options" model="ir.actions.act_window">
        <field name="name">Options</field>
        <field name="res_model">fleet.vehicle.options</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune option enregistrée
            </p>
        </field>
    </record>
    <record id="action_fleet_vehicle_tachy" model="ir.actions.act_window">
        <field name="name">Relevés tachy</field>
        <field name="res_model">fleet.vehicle.tachy</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun relevé enregistré
            </p>
        </field>
    </record>
    <record id="action_fleet_vehicle_reservation" model="ir.actions.act_window">
        <field name="name">Réservations</field>
        <field name="res_model">fleet.vehicle.reservation</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune réservation enregistrée
            </p>
        </field>
    </record>
    <record id="action_fleet_vehicle_provision" model="ir.actions.act_window">
        <field name="name">Provisions</field>
        <field name="res_model">fleet.vehicle.provision</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune provision enregistrée
            </p>
        </field>
    </record>

    <record id="fleet_vehicle_view_tree" model="ir.ui.view">
        <field name="name">Flotte Véhicules</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Flotte Véhicules">
                <field name="license_plate"/>
                <field name="model_id"/>
                <field name="type_stock"/>
                <field name="kilometrage"/>
                <field name="essieux"/>
                <field name="date_production"/>
                <field name="acquisition_date"/>

            </tree>
        </field>
    </record>
    <record id="fleet_vehicle_options_view_tree" model="ir.ui.view">
        <field name="name">Options véhicules</field>
        <field name="model">fleet.vehicle.options</field>
        <field name="arch" type="xml">
            <tree string="Options du véhicule">
                <field name="nom_option"/>
            </tree>
        </field>
    </record>
    <record id="fleet_vehicle_tachy_view_tree" model="ir.ui.view">
        <field name="name">Relevés tachy</field>
        <field name="model">fleet.vehicle.tachy</field>
        <field name="arch" type="xml">
            <tree string="Relevés tachy">
                <field name="date_controle_tachy"/>
                <field name="camion"/>
            </tree>
        </field>
    </record>
    <record id="fleet_vehicle_reservation_view_tree" model="ir.ui.view">
            <field name="name">Reservations</field>
            <field name="model">fleet.vehicle.reservation</field>
            <field name="arch" type="xml">
                <tree string="Réservations">
                    <field name="vehicule"/>
                    <field name="date_debut"/>
                    <field name="date_fin"/>
                    <field name="type_stock"/>
                </tree>
            </field>
    </record>
    <record id="fleet_vehicle_provision_view_tree" model="ir.ui.view">
            <field name="name">Provisions</field>
            <field name="model">fleet.vehicle.provision</field>
            <field name="arch" type="xml">
                <tree editable="top" string="Provisions">
                    <field name="vehicule_provision"/>
                    <field name="date_provision"/>
                    <field name="montant_provision"/>
                    <field name="montant_vr"/>
                    <field name="montant_marche"/>
                </tree>
            </field>
    </record>

    <record id="fleet_vehicle_reservation_view_form" model="ir.ui.view">
            <field name="name">Reservations</field>
            <field name="model">fleet.vehicle.reservation</field>
            <field name="arch" type="xml">
                <form string="Réservation">
                <sheet>
                    <div class="oe_title">
                    </div>
                    <group col="2">
                        <group>
                            <field name="vehicule" />
                            <field name="type_stock"/>
                            <field name="display_name"/>
                        </group>
                        <group>
                            <field name="date_debut" />
                            <field name="date_fin"/>
                            <field name="client_reservation"/>
                            <field name="facturable"/>
                            <field name="num_affaire_vehicle"/>
                        </group>
                    </group>
                    <group string="Vehicules disponibles">
                        <field name="available_vehicles">
                            <tree>
                                <field name="num_affaire"/>
                                <field name="license_plate"/>
                                <field name="model_id"/>
                                <field name="localisation"/>
                                <field name="essieux"/>
                                <field name="kilometrage"/>
                                <field name="has_hydraulique"/>
                            </tree>
                        </field>
                    </group>
                    <notebook>
                        <page string="Other">
                            <group>
                                <group>
                                </group>
                                <group>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
            </field>
    </record>
    <record id="fleet_vehicle_reservation_view_calendar" model="ir.ui.view">
            <field name="name">Reservations</field>
            <field name="model">fleet.vehicle.reservation</field>
            <field name="arch" type="xml">
                <calendar string="Réservations" form_view_id="vehicule" date_start="date_debut" date_stop="date_fin" event_open_popup="true" mode="month" quick_add="False">
                    <field name="vehicule"/>
                    <field name="type_stock"/>
                </calendar>
            </field>
    </record>

    <record id="fleet_vehicle_view_calendar" model="ir.ui.view">
            <field name="name">Livraisons clients</field>
            <field name="model">fleet.vehicle</field>
            <field name="arch" type="xml">
                <calendar string="Livraisons clients" date_start="date_livraison_client" date_stop="date_livraison_client" event_open_popup="true" mode="month" quick_add="False">
                </calendar>
            </field>
    </record>

    <record id="fleet_vehicle_reservation_view_search" model="ir.ui.view">
            <field name="name">Reservations</field>
            <field name="model">fleet.vehicle.reservation</field>
            <field name="arch" type="xml">
                <search >
                    <field name="vehicule"/>
                    <field name="num_affaire_vehicle"/>
                </search>
            </field>
    </record>

    <menuitem id="menu_fleet_vehicle_sda"
         name="SDA"
         parent="fleet.fleet_vehicles"
         action="action_fleet_vehicle_modele_camion"
         sequence="0"/>
    <menuitem id="menu_fleet_vehicle_options"
         name="Options"
         parent="fleet.menu_root"
         action="action_fleet_vehicle_options"
         sequence="0"/>
    <menuitem id="menu_fleet_vehicle_tachy"
         name="Relevés tachy"
         parent="fleet.menu_root"
         action="action_fleet_vehicle_tachy"
         sequence="0"/>
    <menuitem id="menu_fleet_vehicle_reservation"
         name="Réservations"
         parent="fleet.menu_root"
         action="action_fleet_vehicle_reservation"
         sequence="0"/>
    <menuitem id="menu_fleet_vehicle_provision"
         name="Provisions"
         parent="fleet.menu_root"
         action="action_fleet_vehicle_provision"
         sequence="0"/>
    <menuitem id="fleet.fleet_vehicles"
         name="Flotte Véhicules"
         parent="fleet.menu_root"
         sequence="0"/>
    <menuitem id="fleet.fleet_vehicle_menu"
         name="Flotte Véhicules"
         parent="fleet.fleet_vehicles"
         sequence="0"/>
   
    <record id="fleet_vehicle_view_kanban_inherit" model="ir.ui.view">
        <field name="name">fleet.vehicle.kanban.inherit</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban[1]" position="attributes">
                <attribute name="default_group_by">state_id</attribute>
            </xpath> 
                    <xpath expr="//templates" position="replace">
            <templates>
                <t t-name="kanban-box">
                    <div t-if="record.has_active_opportunity.raw_value" t-att-style="'background-color:orange'">
                        <div class="o_kanban_record_top mb2">
                            <div class="oe_kanban_global_click">
                                <div>
                                    <strong class="o_kanban_record_title"><span><field name="model_id"/></span> - <field name="license_plate" widget="badge"/></strong>
                                </div>
                                <div class="oe_kanban_details">
                                    <field name="essieux" display="full"/>
                                    <field name="num_production" display="full"/>
                                    <field name="num_affaire" display="full"/>
                                    <field name="has_active_opportunity" attrs="{'invisible': [('id', '!=', False)]}"/>
                                    <div class="o_kanban_tags_section">
                                    </div>
                                </div>
                                <div>
                                    <strong>N° semaine prod. : <field name="semaine_production"/></strong>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div t-if="!record.has_active_opportunity.raw_value" t-att-style="'background-color:white'">
                        <div class="o_kanban_record_top mb2">
                            <div class="oe_kanban_global_click">
                                <div>
                                    <strong class="o_kanban_record_title"><span><field name="model_id"/></span> - <field name="license_plate" widget="badge"/></strong>
                                </div>
                                <div class="oe_kanban_details">
                                    <field name="essieux" display="full"/>
                                    <field name="num_production" display="full"/>
                                    <field name="num_affaire" display="full"/>
                                    <field name="has_active_opportunity" attrs="{'invisible': [('id', '!=', False)]}"/>
                                    <div class="o_kanban_tags_section">
                                    </div>
                                </div>
                                <div>
                                    <strong>N° semaine prod. : <field name="semaine_production"/></strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </templates>
        </xpath> 
        </field>
    </record>
    <record id="view_attachment_form_inherit_vehicle" model="ir.ui.view">
        <field name="name">ir.attachment.form.inherit.vehicle</field>
        <field name="model">ir.attachment</field>
        <field name="inherit_id" ref="base.view_attachment_form"/>
        <field name="arch" type="xml">
            <field name="mimetype" position="after">
                <field name="is_sda"/>
                <field name="vehicle_id"/>
                <field name="is_sda_reference"/>
                <field name="is_sda_definitive"/>
            </field>
        </field>
    </record>
<record id="view_crm_lead_form_inherit" model="ir.ui.view">
    <field name="name">crm.lead.form.inherit.vehicle</field>
    <field name="model">crm.lead</field>
    <field name="inherit_id" ref="crm.crm_lead_view_form"/>
    <field name="arch" type="xml">
        <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
            <!-- Preload all the partner's information -->
            <group>
                <field name="vehicle_ids" widget="many2many" options="{'no_create': False}" attrs="{'invisible': [('type', '!=', 'opportunity')]}"/>
                <field name="specifications_vehicule"/>
            </group>
        </xpath>
        <xpath expr="//notebook/page[1]" position="before">
            <page string="Infos Immat. A l’origine de la piste ">
                <group>
                    <group>
                        <field name="x_code_departement"/>
                        <field name="x_code_postal"/>
                        <field name="x_ville"/>
                        <field name="x_date_immatriculation"/>
                        <field name="x_annee_carte_grise"/>
                    </group>
                    <group>
                        <field name="x_marque"/>
                        <field name="x_numero_serie"/>
                        <field name="x_genre"/>
                        <field name="x_ptr"/>
                        <field name="x_ptac"/>
                    </group>
                </group>
                <group>
                    <field name="x_carrosserie"/>
                    <field name="x_profil_client"/>
                    <field name="x_protocole_daf"/>
                    <field name="x_regroupement_daf"/>
                    <field name="x_siret"/>
                    <field name="x_immatriculation"/>
                    <field name="x_charge_utile"/>
                    <field name="x_cylindree"/>
                    <field name="x_denomination"/>
                    <field name="x_poids_a_vide"/>
                </group>
            </page>
        </xpath>
    </field>
</record>


    <record id="view_fleet_vehicle_calendar_production" model="ir.ui.view">
        <field name="name">fleet.vehicle.calendar.production</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <calendar string="Production Calendar" date_start="date_production" mode="month">
                <!-- Autres éléments et attributs pour personnaliser la vue -->
            </calendar>
        </field>
    </record>
    <record id="action_fleet_vehicle_calendar_production" model="ir.actions.act_window">
        <field name="name">Production</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="view_fleet_vehicle_calendar_production"/>
    </record>
    <menuitem id="menu_fleet_vehicle_calendar_production" 
          name="Production" 
          action="action_fleet_vehicle_calendar_production" 
          parent="fleet.fleet_vehicles"
          sequence="0"/>

</odoo>
