<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="weenect_view_order_product_search" model="ir.ui.view">
        <field name="name">weenect/sale.report.search</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.view_order_product_search"/>
        <field name="arch" type="xml">
            <filter name="company" position="after">
                <filter string="Groupe Retailer" name="groupe_retailer" context="{'group_by':'groupe_retailer'}"/>
            </filter>
        </field>
    </record>
</odoo>